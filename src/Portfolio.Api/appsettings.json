{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "Serilog": {
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft": "Warning",
          "System": "Warning"
        }
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PortfolioCMS;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=true;",
    "PostgresConnection": "Host=localhost;Port=5432;Database=PortfolioCMS;Username=postgres;Password=YourPassword;"
  },
  "DatabaseProvider": "SqlServer",
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "PortfolioCMS",
    "Audience": "PortfolioCMSUsers",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AllowedHosts": "*",
  "CorsOrigins": [
    "http://localhost:4200",
    "https://localhost:4200"
  ],
  "SecuritySettings": {
    "PasswordMinLength": 8,
    "PasswordRequireDigit": true,
    "PasswordRequireLowercase": true,
    "PasswordRequireUppercase": true,
    "PasswordRequireNonAlphanumeric": true,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "RateLimitPerMinute": 100
  },
  "FileUploadSettings": {
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".doc", ".docx"],
    "UploadPath": "uploads"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@portfoliocms.com",
    "SenderName": "Portfolio CMS",
    "UseSsl": true,
    "Username": "",
    "Password": ""
  },
  "CacheSettings": {
    "EnableRedis": false,
    "RedisConnectionString": "localhost:6379",
    "DefaultCacheDurationMinutes": 30
  },
  "MaintenanceMode": {
    "Enabled": false,
    "Message": "Site is under maintenance. Please check back later."
  }
}
