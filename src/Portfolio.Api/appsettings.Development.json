{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PortfolioCMS;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=true;"
  },
  "DatabaseProvider": "SqlServer",
  "JwtSettings": {
    "SecretKey": "DevelopmentSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "PortfolioCMS",
    "Audience": "PortfolioCMSUsers",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AllowedHosts": "*",
  "CorsOrigins": [
    "http://localhost:4200",
    "https://localhost:4200"
  ],
  "SecuritySettings": {
    "PasswordMinLength": 6,
    "PasswordRequireDigit": false,
    "PasswordRequireLowercase": false,
    "PasswordRequireUppercase": false,
    "PasswordRequireNonAlphanumeric": false,
    "MaxLoginAttempts": 10,
    "LockoutDurationMinutes": 5,
    "RateLimitPerMinute": 200
  },
  "FileUploadSettings": {
    "MaxFileSizeMB": 50,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".doc", ".docx", ".mp4", ".avi"],
    "UploadPath": "uploads"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@portfoliocms.com",
    "SenderName": "Portfolio CMS",
    "UseSsl": true,
    "Username": "",
    "Password": ""
  },
  "CacheSettings": {
    "EnableRedis": false,
    "RedisConnectionString": "localhost:6379",
    "DefaultCacheDurationMinutes": 5
  },
  "MaintenanceMode": {
    "Enabled": false,
    "Message": "Site is under maintenance. Please check back later."
  }
}
