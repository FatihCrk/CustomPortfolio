# Database Configuration
# For PostgreSQL:
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=PortfolioCMS
DB_USER=postgres
DB_PASSWORD=YourSecurePassword123!

# For SQL Server (uncomment to use):
# DB_TYPE=mssql
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=PortfolioCMS
# DB_USER=sa
# DB_PASSWORD=YourStrong@Passw0rd!

# Connection String (auto-generated from above, or set manually)
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=PortfolioCMS;Username=postgres;Password=YourSecurePassword123!

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# JWT Settings
Jwt__Key=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
Jwt__Issuer=PortfolioCMS
Jwt__Audience=PortfolioCMSUsers
Jwt__ExpirationInMinutes=60
Jwt__RefreshTokenExpirationInDays=7

# Security Settings
Security__PasswordMinLength=8
Security__MaxFailedLoginAttempts=5
Security__LockoutDurationInMinutes=30
Security__RequireDigit=true
Security__RequireLowercase=true
Security__RequireUppercase=true
Security__RequireNonAlphanumeric=true

# Email Settings (SMTP)
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your-email@gmail.com
Smtp__Password=your-app-password
Smtp__EnableSsl=true
Smtp__FromName=Portfolio CMS
Smtp__FromEmail=noreply@portfoliocms.com

# File Upload Settings
FileUpload__MaxFileSizeMB=10
FileUpload__AllowedExtensions=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx
FileUpload__StoragePath=./uploads

# Serilog Settings
Serilog__MinimumLevel=Information
Serilog__WriteTo__Console__Enabled=true
Serilog__WriteTo__File__Enabled=true
Serilog__WriteTo__File__Path=logs/log-.txt

# Redis Cache (Optional)
Redis__Enabled=false
Redis__ConnectionString=localhost:6379

# Rate Limiting
RateLimit__MaxRequestsPerMinute=100

# Maintenance Mode
MaintenanceMode__Enabled=false
